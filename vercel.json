{
  "version": 2,
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/", "dest": "/tienda.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=0, stale-while-revalidate" }
      ]
    }
  ]
}
